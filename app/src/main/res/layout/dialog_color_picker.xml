<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center">

        <TextView
            android:id="@+id/tvTitle"
            style="@style/single_marquee"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginHorizontal="100dp"
            android:background="@drawable/bg_title_dialog_loading"
            android:elevation="2dp"
            android:fontFamily="@font/janda_manatee_solid"
            android:gravity="center"
            android:paddingHorizontal="15dp"
            android:layout_marginBottom="-34dp"
            android:text="@string/choose_color"
            android:textColor="@color/app_color"
            android:textSize="20sp"
            app:layout_constraintBottom_toTopOf="@+id/constraintLayout2"
            app:layout_constraintDimensionRatio="1.6:0.645"
            app:layout_constraintEnd_toEndOf="@+id/constraintLayout2"
            app:layout_constraintStart_toStartOf="@+id/constraintLayout2"
            app:strokeJoinStyle="miter" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintLayout2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_choose_color"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:layout_editor_absoluteX="16dp">




            <ir.kotlin.kavehcolorpicker.KavehColorPicker
                android:id="@+id/colorPickerView"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="50dp"
                android:layout_marginHorizontal="13dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/colorPickerView">


                <!--                btnDone-->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RelativeLayout
                        android:id="@+id/relativeTxtColor"
                        android:layout_width="0dp"
                        android:layout_height="24dp"
                        android:layout_marginHorizontal="3dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ir.kotlin.kavehcolorpicker.KavehHueSlider
                            android:id="@+id/hueSlider"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </RelativeLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnDone"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="22dp"
                        android:gravity="center"
                        app:cardCornerRadius="0dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintDimensionRatio="1.3:0.4"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/btnClose"
                        app:layout_constraintTop_toBottomOf="@+id/relativeTxtColor"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitXY"
                            android:src="@drawable/bg_view_mywork" />

                        <ImageView
                            android:id="@+id/img_dialog1_1_frame"

                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginHorizontal="9dp"
                            android:layout_marginBottom="2.8dp"
                            android:adjustViewBounds="true"
                            android:scaleType="fitXY"
                            android:src="@drawable/bg_view_bottom1_mywork"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintDimensionRatio="1.14:0.25"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/txtDone"
                            style="@style/single_marquee"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginHorizontal="9dp"
                            android:fontFamily="@font/janda_manatee_solid"
                            android:gravity="center"
                            android:text="@string/save"
                            android:textColor="@color/app_color"
                            android:textSize="18sp"
                            app:layout_constraintBottom_toBottomOf="@+id/img_dialog1_1_frame"
                            app:layout_constraintEnd_toEndOf="@+id/img_dialog1_1_frame"
                            app:layout_constraintStart_toStartOf="@+id/img_dialog1_1_frame"
                            app:layout_constraintTop_toTopOf="@+id/img_dialog1_1_frame"
                            app:outerStrokeColor="@color/app_color"
                            app:outerStrokeJoinStyle="miter"
                            app:outerStrokeWidth="1dp" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnClose"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="8dp"


                        android:gravity="center"
                        app:layout_constraintBottom_toBottomOf="@+id/btnDone"
                        app:layout_constraintDimensionRatio="1.3:0.4"
                        app:layout_constraintEnd_toStartOf="@+id/btnDone"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/btnDone">

                        <ImageView
                            android:id="@+id/imageView3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitXY"
                            android:src="@drawable/bg_view_mywork" />

                        <ImageView
                            android:id="@+id/img_dialog2_1_frame"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginHorizontal="9dp"
                            android:layout_marginBottom="2.8dp"
                            android:adjustViewBounds="true"
                            android:scaleType="fitXY"
                            android:src="@drawable/bg_view_bottom1_mywork"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintDimensionRatio="1.14:0.25"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/txtCancel"
                            style="@style/single_marquee"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginHorizontal="9dp"
                            android:fontFamily="@font/hvd_comic_serif_pro"
                            android:gravity="center"
                            android:text="@string/tv_cancel"
                            android:textColor="@color/app_color"
                            android:textSize="18sp"
                            app:layout_constraintStart_toStartOf="@+id/img_dialog2_1_frame"
                            app:layout_constraintEnd_toEndOf="@+id/img_dialog2_1_frame"
                            app:layout_constraintBottom_toBottomOf="@+id/img_dialog2_1_frame"
                            app:layout_constraintTop_toTopOf="@+id/img_dialog2_1_frame"
                            app:outerStrokeColor="@color/app_color"
                            app:outerStrokeJoinStyle="miter"
                            app:outerStrokeWidth="1dp" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>