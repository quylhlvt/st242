<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#3D000000"
        android:gravity="center">

        <TextView
            android:id="@+id/txtTitle"
            style="@style/single_marquee"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginHorizontal="100dp"
            android:layout_marginBottom="-40dp"
            android:background="@drawable/bg_title_dialog_loading"
            android:elevation="2dp"
            android:fontFamily="@font/janda_manatee_solid"
            android:gravity="center"
            android:paddingHorizontal="15dp"
            android:text="@string/loading"
            android:textColor="@color/app_color"
            android:textSize="20sp"
            app:layout_constraintBottom_toTopOf="@+id/constraintLayout"
            app:layout_constraintDimensionRatio="1.6:0.68"
            app:layout_constraintEnd_toEndOf="@+id/constraintLayout"
            app:layout_constraintStart_toStartOf="@+id/constraintLayout"
            app:strokeJoinStyle="miter" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintLayout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_dialog_loading"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="3.28:2.06"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

<!--            <ImageView-->
<!--                android:id="@+id/imgInLoading"-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_height="0dp"-->
<!--                android:layout_margin="20dp"-->
<!--                android:adjustViewBounds="true"-->
<!--                android:scaleType="fitXY"-->
<!--                android:src="@drawable/img_in_loading"-->
<!--                app:layout_constraintBottom_toBottomOf="parent"-->
<!--                app:layout_constraintEnd_toEndOf="parent"-->
<!--                app:layout_constraintStart_toStartOf="parent"-->
<!--                app:layout_constraintTop_toTopOf="parent" />-->


            <TextView
                android:id="@+id/txtContent1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="17dp"
                android:elevation="1dp"
                android:fontFamily="@font/hvd_comic_serif_pro"
                android:gravity="center"
                android:text="@string/haven_t_saved_it_yet_do_you_want_to_exit"
                android:textColor="@color/app_color"
                android:textSize="18sp"
                android:layout_marginTop="30dp"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@+id/btnOk"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <TextView
                android:id="@+id/txtContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="17dp"
                android:fontFamily="@font/hvd_comic_serif_pro"
                android:gravity="center"
                android:text="@string/haven_saved_it_yet_are_you_sure_to_exit"
                android:textColor="@color/app_color"
                android:layout_marginTop="30dp"
                android:textSize="18sp"
                app:layout_constraintBottom_toTopOf="@+id/btnYes"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnOk"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginHorizontal="110dp"
                android:layout_marginBottom="30dp"
                android:gravity="center"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1.3:0.4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_view_mywork" />

                <ImageView
                    android:id="@+id/img_dialogok1_frame"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="9dp"
                    android:layout_marginBottom="2.8dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_view_bottom1_mywork"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1.14:0.25"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txtOk"
                    style="@style/single_marquee"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="10dp"
                    android:fontFamily="@font/janda_manatee_solid"
                    android:gravity="center"
                    android:text="@string/ok"
                    android:textColor="@color/app_color"
                    android:textSize="18sp"
                    app:layout_constraintBottom_toBottomOf="@+id/img_dialogok1_frame"
                    app:layout_constraintTop_toTopOf="@+id/img_dialogok1_frame"
                    app:outerStrokeColor="@color/app_color"
                    app:outerStrokeJoinStyle="miter"
                    app:outerStrokeWidth="1dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnYes"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="38dp"
                android:layout_marginBottom="30dp"
                android:gravity="center"
                app:cardCornerRadius="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1.3:0.4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/btnNo"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_view_dialog_exit" />

                <ImageView
                    android:id="@+id/img_dialog1_1_frame"

                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="9dp"
                    android:layout_marginBottom="2.8dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_view_bottom1_mywork"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1.14:0.25"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView
                    android:id="@+id/txtYes"
                    style="@style/single_marquee"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="9dp"
                    android:fontFamily="@font/janda_manatee_solid"
                    android:gravity="center"
                    android:text="@string/tv_yes"
                    android:textColor="@color/app_color"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="@+id/img_dialog1_1_frame"
                    app:layout_constraintEnd_toEndOf="@+id/img_dialog1_1_frame"
                    app:layout_constraintBottom_toBottomOf="@+id/img_dialog1_1_frame"
                    app:layout_constraintTop_toTopOf="@+id/img_dialog1_1_frame"
                    app:outerStrokeColor="@color/app_color"
                    app:outerStrokeJoinStyle="miter"
                    app:outerStrokeWidth="1dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnNo"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="38dp"
                android:layout_marginEnd="8dp"


                android:gravity="center"
                app:layout_constraintBottom_toBottomOf="@+id/btnYes"
                app:layout_constraintDimensionRatio="1.3:0.4"
                app:layout_constraintEnd_toStartOf="@+id/btnYes"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/btnYes">

                <ImageView
                    android:id="@+id/imageView3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_view_dialog_exit" />

                <ImageView
                    android:id="@+id/img_dialog2_1_frame"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="9dp"
                    android:layout_marginBottom="2.8dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_view_bottom1_mywork"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1.14:0.25"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txtNo"
                    style="@style/single_marquee"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="9dp"
                    android:fontFamily="@font/hvd_comic_serif_pro"
                    android:gravity="center"
                    android:text="@string/tv_no"
                    android:textColor="@color/app_color"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="@+id/img_dialog2_1_frame"
                    app:layout_constraintEnd_toEndOf="@+id/img_dialog2_1_frame"
                    app:layout_constraintBottom_toBottomOf="@+id/img_dialog2_1_frame"
                    app:layout_constraintTop_toTopOf="@+id/img_dialog2_1_frame"
                    app:outerStrokeColor="@color/app_color"
                    app:outerStrokeJoinStyle="miter"
                    app:outerStrokeWidth="1dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>