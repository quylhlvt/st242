            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnCreate"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginHorizontal="16dp"
                app:layout_constraintDimensionRatio="3.28:0.82"

                app:layout_constraintBottom_toTopOf="@+id/btnCosplay"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">


                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:background="@drawable/img_frame_home"
                        android:layout_height="match_parent">


                        <com.cute.anime.avatarmaker.utils.OuterStrokeTextView
                            android:paddingHorizontal="5dp"
                            android:id="@+id/tv1"
                            style="@style/single_marquee"
                            android:layout_width="0dp"
                            android:gravity="center"
                            android:layout_height="0dp"
                            android:elevation="2dp"
                            android:fontFamily="@font/fredoka_one_regular"
                            android:shadowColor="#241C39"
                            android:shadowDx="2"
                            android:shadowDy="10"
                            android:shadowRadius="1"
                            android:text="@string/pony_maker"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:outerStrokeColor="@color/app_color2"
                            app:outerStrokeWidth="1.2dp" />

                    </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnCosplay"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginHorizontal="16dp"
                app:layout_constraintDimensionRatio="3.28:0.82"

                android:layout_marginTop="8dp"
                app:layout_constraintBottom_toTopOf="@+id/btnRandom"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnCreate">


                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:background="@drawable/img_frame_home"
                        android:layout_height="match_parent">

                        <com.cute.anime.avatarmaker.utils.OuterStrokeTextView
                            android:id="@+id/tv2"
                            style="@style/single_marquee"
                            android:layout_width="0dp"
                            android:paddingEnd="2dp"
                            android:gravity="center"
                            android:layout_height="0dp"
                            android:elevation="2dp"
                            android:fontFamily="@font/fredoka_one_regular"
                            android:shadowColor="#241C39"
                            android:shadowDx="2"
                            android:shadowDy="10"
                            android:shadowRadius="1"
                            android:text="@string/cosplay_nuggts"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:outerStrokeColor="@color/app_color2"
                            app:outerStrokeWidth="1.2dp" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

     <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnRandom"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginHorizontal="16dp"
         app:layout_constraintDimensionRatio="3.28:0.82"
         app:cardCornerRadius="20dp"

                android:layout_marginTop="8dp"
                app:layout_constraintBottom_toTopOf="@+id/btnMyWork"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnCosplay">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:background="@drawable/img_frame_home"
                        android:layout_height="match_parent">


                        <com.cute.anime.avatarmaker.utils.OuterStrokeTextView
                            android:id="@+id/tv3"
                            style="@style/single_marquee"
                            android:layout_width="0dp"
                            android:gravity="center"
                            android:paddingStart="2dp"
                            android:layout_height="0dp"
                            android:elevation="2dp"
                            android:fontFamily="@font/fredoka_one_regular"
                            android:shadowColor="#241C39"
                            android:shadowDx="2"
                            android:shadowDy="10"
                            android:shadowRadius="1"
                            android:text="@string/random_cat"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:outerStrokeColor="@color/app_color2"
                            app:outerStrokeWidth="1.2dp" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
     <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnMyWork"
                android:layout_width="match_parent"
                android:layout_height="0dp"
         app:cardCornerRadius="20dp"
         app:layout_constraintDimensionRatio="3.28:0.82"
         android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintBottom_toTopOf="@+id/space"

         app:layout_constraintTop_toBottomOf="@+id/btnRandom">


                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:background="@drawable/img_frame_home"
                        android:layout_height="match_parent">

                        <com.cute.anime.avatarmaker.utils.OuterStrokeTextView
                            android:id="@+id/tv4"
                            style="@style/single_marquee"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:elevation="2dp"
                            android:gravity="center"
                            android:fontFamily="@font/fredoka_one_regular"
                            android:paddingStart="2dp"
                            android:shadowColor="#241C39"
                            android:shadowDx="2"
                            android:shadowDy="10"
                            android:shadowRadius="1"
                            app:outerStrokeJoinStyle="miter"
                            android:text="@string/my_avatar"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:outerStrokeColor="@color/app_color2"
                            app:outerStrokeWidth="1.2dp" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
            <Space
                android:id="@+id/space"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_width="match_parent"
                android:layout_height="20dp"/>


        </androidx.constraintlayout.widget.ConstraintLayout>



