                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">


                        <!--            imvImage-->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="20dp"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="38dp"
                            app:cardBackgroundColor="@color/transparent"
                            app:cardCornerRadius="14dp"
                            app:strokeColor="@color/app_color2"
                            app:strokeWidth="2dp">

                            <ImageView
                                android:id="@+id/imgCharacter2Show"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop" />

                        </com.google.android.material.card.MaterialCardView>


                    </FrameLayout>


                </androidx.constraintlayout.widget.ConstraintLayout>


                <!-- Loading Progress -->
                <!--                    <ProgressBar-->
                <!--                        android:id="@+id/progressBar"-->
                <!--                        android:layout_width="64dp"-->
                <!--                        android:layout_height="64dp"-->
                <!--                        android:layout_gravity="center"-->
                <!--                        android:indeterminateTint="@color/app_color" />-->

            </FrameLayout>

        <ImageView
            android:id="@+id/closeImage"
            android:layout_width="40dp"
            android:layout_height="40dp"

            android:src="@drawable/ic_close_dialog_cosplay"
            android:layout_marginTop="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/frameShowImage" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <FrameLayout
            android:id="@+id/frameImageSmall"
            android:layout_width="80dp"
            android:layout_height="0dp"
            android:elevation="5dp"
            app:layout_constraintDimensionRatio="1:1"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:background="@color/transparent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imvBack">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_small">


                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">


                    <!--            imvImage-->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginHorizontal="6dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="10dp"
                        app:cardBackgroundColor="@color/transparent"
                        app:cardCornerRadius="8dp"
                        app:strokeColor="@color/app_color2"
                        app:strokeWidth="0.4dp">

                        <ImageView
                            android:id="@+id/imgCharacter1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop" />

                    </com.google.android.material.card.MaterialCardView>


                </FrameLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>


            <!-- Loading Progress -->
            <!--                    <ProgressBar-->
            <!--                        android:id="@+id/progressBar"-->
            <!--                        android:layout_width="64dp"-->
            <!--                        android:layout_height="64dp"-->
            <!--                        android:layout_gravity="center"-->
            <!--                        android:indeterminateTint="@color/app_color" />-->

        </FrameLayout>

        <!--            app:layout_constraintTop_toBottomOf="@+id/btnSave" />-->
