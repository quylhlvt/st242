                app:layout_constraintStart_toEndOf="@+id/btnReset"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutProgress"
            android:layout_width="40dp"
            android:layout_marginEnd="12dp"
            android:elevation="8dp"
            android:layout_marginTop="9dp"
            android:layout_height="0dp"
            android:layout_marginBottom="15dp"
            android:clipChildren="false"
            android:clipToPadding="false"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/tvMatchPercent"
            app:layout_constraintTop_toTopOf="@+id/rl">

            <!-- 1. Track nền cam - elevation thấp nhất -->
            <ImageView
                android:id="@+id/progressTrack"
                android:layout_width="20dp"
                android:layout_height="0dp"
                android:elevation="0dp"
                android:src="@drawable/bg_progress_track"
                android:scaleType="fitXY"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- 2. Fill tím rectangle - trượt từ dưới lên -->
            <ImageView
                android:id="@+id/progressFill"
                android:layout_width="17dp"
                android:layout_height="0dp"
                android:elevation="1dp"
                android:layout_marginBottom="10dp"
                android:src="@drawable/bg_progress_match"
                android:scaleType="fitXY"
                android:scaleY="0"
                app:layout_constraintBottom_toBottomOf="@id/progressTrack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/progressTrack" />

            <!-- 3. Bottom cố định ở đáy - đè lên fill -->
            <ImageView
                android:id="@+id/progressTrackBottom"
                android:layout_width="17dp"
                android:layout_height="wrap_content"
                android:elevation="2dp"
                android:adjustViewBounds="true"
                android:src="@drawable/ic_progress_track_bottom"
                android:scaleType="fitXY"
                android:translationY="-2dp"
                app:layout_constraintBottom_toBottomOf="@id/progressTrack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- 4. Sao - elevation cao nhất, bám đỉnh fill -->
            <ImageView
                android:id="@+id/imgStar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:elevation="3dp"
                android:src="@drawable/ic_star"
                android:translationY="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tvMatchPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/fredoka_one_regular"
            android:text="0%"
            android:elevation="8dp"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:textColor="@color/app_color"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@+id/guidelineHorizontal"
            app:layout_constraintEnd_toEndOf="@+id/layoutProgress"

            app:layout_constraintStart_toStartOf="@+id/layoutProgress" />
        <RelativeLayout
            android:id="@+id/rl"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="5dp"
            android:elevation="0dp"
            android:visibility="visible"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/guidelineHorizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnSwitchCharacter" />

        <!--        <androidx.appcompat.widget.AppCompatImageView-->
        <!--            android:id="@+id/btnDice"-->
