<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout

        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/img_bg_splash">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imvBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="60dp"
            android:elevation="2dp"
            android:src="@drawable/ic_back_app"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imvNext"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="60dp"
            android:layout_marginEnd="20dp"
            android:elevation="1dp"
            android:src="@drawable/ic_next"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/titleRandom"
            style="@style/single_marquee"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="marquee"
            android:focusable="true"

            android:focusableInTouchMode="true"
            android:fontFamily="@font/janda_manatee_solid"
            android:freezesText="true"
            android:gravity="center"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:text="@string/random"
            android:textColor="@color/app_color"
            android:textSize="24sp"

            app:layout_constraintBottom_toBottomOf="@id/imvBack"
            app:layout_constraintEnd_toStartOf="@+id/imvNext"
            app:layout_constraintStart_toEndOf="@id/imvBack"
            app:layout_constraintTop_toTopOf="@id/imvBack" />
        <!-- Character Image Container -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCharacter"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="50dp"
            app:cardBackgroundColor="@color/transparent"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imvBack">

            <FrameLayout

                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/transparent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_ramdom"

                    >


                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">


                        <!--            imvImage-->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="20dp"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="38dp"
                            app:cardBackgroundColor="@color/transparent"
                            app:cardCornerRadius="14dp"
                            app:strokeColor="@color/app_color2"
                            app:strokeWidth="2dp">

                            <ImageView
                                android:id="@+id/imgCharacter"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop" />

                        </com.google.android.material.card.MaterialCardView>


                    </FrameLayout>


                </androidx.constraintlayout.widget.ConstraintLayout>


                <!-- Loading Progress -->
                <!--                    <ProgressBar-->
                <!--                        android:id="@+id/progressBar"-->
                <!--                        android:layout_width="64dp"-->
                <!--                        android:layout_height="64dp"-->
                <!--                        android:layout_gravity="center"-->
                <!--                        android:indeterminateTint="@color/app_color" />-->

            </FrameLayout>

        </androidx.cardview.widget.CardView>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnRandomize"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginHorizontal="110dp"
            android:layout_marginTop="45dp"
            android:layout_weight="1"
            android:gravity="center"
            app:layout_constraintDimensionRatio="1.56:0.32"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:background="@drawable/img_frame_mywork1_1"
            app:layout_constraintTop_toBottomOf="@+id/cardCharacter">




            <com.anime.couple.couplemaker.utils.OuterStrokeTextView
                android:id="@+id/tv1"
                style="@style/single_marquee"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginHorizontal="10dp"
                android:fontFamily="@font/fredoka_one_regular"
                android:gravity="center"
                android:text="@string/random"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:outerStrokeColor="@color/app_color"
                app:outerStrokeJoinStyle="miter"
                app:outerStrokeWidth="0.4dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Random Button -->

        <!--        &lt;!&ndash;    flNativeCollab&ndash;&gt;-->
        <!--        <FrameLayout-->
        <!--            android:id="@+id/flNativeCollab"-->
        <!--            android:layout_width="match_parent"-->
        <!--            android:layout_height="wrap_content"-->
        <!--            app:layout_constraintBottom_toBottomOf="parent" />-->
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>